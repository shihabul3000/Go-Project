APP_ENV=development
PORT=8080

# PostgreSQL DSN from NeonDB, Supabase, Aiven, or local Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spotsync?sslmode=disable

# Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h
BCRYPT_COST=12

# Comma separated list, or * for all origins in development.
ALLOWED_ORIGINS=*

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
